# ─── Kakao API Keys ─────────────────────────────────────────────────────────────
# Replace with real keys from https://developers.kakao.com/
EXPO_PUBLIC_KAKAO_REST_KEY="MOCK_REST_KEY"
EXPO_PUBLIC_KAKAO_JS_KEY="MOCK_JS_KEY"
EXPO_PUBLIC_KAKAO_APP_KEY="MOCK_APP_KEY"
EXPO_PUBLIC_KAKAO_SHARE_IMAGE_URL=""

# ─── Anthropic API (Self-AI, Weekly Report, Crisis, AI Muse, Date Shuttle) ──────
# Required for all LLM features. Get key from https://console.anthropic.com/
# Without this key, all AI responses fall back to local stub templates.
EXPO_PUBLIC_ANTHROPIC_API_KEY=""

# ─── OpenWeatherMap API (Weather Widget, AI Muse context) ───────────────────────
# Required for live weather data in date recommendations.
# Free tier at https://openweathermap.org/api — sufficient for dev.
EXPO_PUBLIC_OPENWEATHER_API_KEY=""

# ─── Backend API Base URL ────────────────────────────────────────────────────────
# Set to your deployed backend URL. Leave empty to run in local-stub mode
# (all backend calls return graceful no-ops / mock responses).
EXPO_PUBLIC_API_BASE_URL=""

# ─── Supabase (Realtime 채팅 + Storage 미디어 업로드) ───────────────────────────
# Required for live couple chat and media file uploads.
# Get values from https://supabase.com/dashboard → Project Settings → API
# Both keys must be set together; missing either one activates simulation fallback.
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
